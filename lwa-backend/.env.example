ENVIRONMENT=development
LWA_APP_NAME=LWA Backend
LWA_DEFAULT_PLAN_NAME=Starter Trial
LWA_DEFAULT_CREDITS_REMAINING=2
LWA_DEFAULT_TURNAROUND=45 seconds
ALLOWED_ORIGINS=*
API_BASE_URL=
LWA_API_KEY_HEADER_NAME=x-api-key
LWA_API_KEY_SECRET=
LWA_JWT_SECRET=
LWA_JWT_EXP_MINUTES=43200
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
LWA_VIDEO_ENCODER=libx264
YT_DLP_TEMP_DIR=/tmp
YT_COOKIES_B64=
LWA_GENERATED_ASSETS_DIR=
LWA_GENERATED_ASSET_RETENTION_HOURS=72
LWA_GENERATED_ASSET_PRUNE_INTERVAL_SECONDS=1800
LWA_UPLOADS_DIR=
LWA_USAGE_STORE_PATH=
LWA_ABUSE_WINDOW_SECONDS=300
LWA_ABUSE_MAX_GENERATION_REQUESTS=8
LOG_LEVEL=info
MAX_UPLOAD_MB=500

# Entitlement tiers — comma-separated API keys per tier
LWA_PRO_API_KEYS=
LWA_SCALE_API_KEYS=
LWA_FREE_CLIP_LIMIT=3
LWA_PRO_CLIP_LIMIT=6
LWA_SCALE_CLIP_LIMIT=12

# AI provider settings
LWA_AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LWA_ENABLE_ANTHROPIC=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
LWA_PREMIUM_REASONING_PROVIDER=anthropic
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# Auto Editor Brain (optional overrides — uses Anthropic/OpenAI keys above)
LWA_AUTO_EDITOR_LLM_TIMEOUT=8
LWA_AUTO_EDITOR_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
LWA_AUTO_EDITOR_OPENAI_MODEL=gpt-4o-mini

# Visual engine / video generation
LWA_VISUAL_ENGINE_ENABLED=true
LWA_VISUAL_ENGINE_API_KEY=
LWA_VISUAL_ENGINE_API_BASE_URL=
LWA_VISUAL_ENGINE_TIMEOUT_SECONDS=180
LWA_VISUAL_ENGINE_MAX_RENDERS_PER_REQUEST=1

# Seedance visual adapter (optional)
SEEDANCE_ENABLED=false
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=
SEEDANCE_MODEL=seedance-2.0
SEEDANCE_TIMEOUT_SECONDS=180
SEEDANCE_POLL_INTERVAL_SECONDS=3

# Whop — live access and entitlement verification
WHOP_API_KEY=
WHOP_COMPANY_ID=
WHOP_PRODUCT_ID=
WHOP_WEBHOOK_SECRET=
LWA_ENABLE_WHOP_VERIFICATION=false

# Stripe Connect — marketplace payout layer (Phase 1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Google / YouTube
GOOGLE_API_KEY=
YOUTUBE_API_KEY=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Meta (Facebook / Instagram)
META_APP_ID=
META_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# Reddit (trend signals)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=LWA-TrendBot/1.0

# X / Twitter (optional social posting)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Discord (optional community notifications)
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# LinkedIn (optional social posting)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# Snapchat (optional)
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Pinterest (optional)
PINTEREST_ACCESS_TOKEN=
