    "council_owner": "Engineering Council",
    "raises": ["clean audio", "valid aspect ratio", "sufficient length", "good lighting"],
    "lowers": ["corrupt segments", "very low resolution", "clip < 8 seconds"],
    "backend_method": "technical_quality_checks"
  },
  {
    "id": "commercial_value_score",
    "display_name": "Commercial Value",
    "description": "Likelihood the clip can drive commercial outcomes — leads, sales, community joins.",
