    "lowers": ["no natural discussion thread", "fully self-contained"],
    "backend_method": "share_trigger_detection + question_ending_detection"
  },
  {
    "id": "render_readiness_score",
    "display_name": "Render Readiness",
    "description": "Technical quality of the source that determines whether a render is possible.",
